{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "TZ"
        },
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Mobile|Android|iPhone|iPad|iPod).*"
        }
      ],
      "dest": "https://wakora.site/$1",
      "status": 307
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
